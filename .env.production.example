# =============================================================================
# Production Environment Variables — Kerala Delivery Route Optimizer
# =============================================================================
# Copy this file to .env.production and fill in REAL values before deploying.
#
#   cp .env.production.example .env.production
#   nano .env.production  # fill in values
#
# SECURITY: .env.production contains secrets. NEVER commit it to git.
# It's already in .gitignore. If you accidentally commit it, rotate ALL
# keys immediately (API_KEY, POSTGRES_PASSWORD, GOOGLE_MAPS_API_KEY).
# =============================================================================

# ── Domain ────────────────────────────────────────────────────────────────────
# Your production domain. Caddy will automatically get a TLS certificate
# from Let's Encrypt for this domain. DNS must point to this server FIRST.
# Use "localhost" for local testing (Caddy uses a self-signed cert).
DOMAIN=delivery.example.com

# ── API Authentication ────────────────────────────────────────────────────────
# REQUIRED in production. All POST/PUT/DELETE requests need this in the
# X-API-Key header. Generate a strong random key:
#   openssl rand -hex 32
API_KEY=CHANGE-ME-generate-with-openssl-rand-hex-32

# Environment — affects security warnings and behavior.
ENVIRONMENT=production

# ── Google Maps ───────────────────────────────────────────────────────────────
# Geocoding API key. Get one at: https://console.cloud.google.com/apis/credentials
# Enable "Geocoding API". Free $200/month credit covers ~40,000 requests.
# With caching, 50 deliveries/day costs ~$1-2/month after initial address loading.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# CHANGE THE PASSWORD. Generate a strong one:
#   openssl rand -base64 24
POSTGRES_USER=routing
POSTGRES_PASSWORD=CHANGE-ME-generate-with-openssl-rand-base64-24
POSTGRES_DB=routing_opt

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your actual production domain(s). Must include the scheme (https://).
# Multiple origins: comma-separated, no spaces.
CORS_ALLOWED_ORIGINS=https://delivery.example.com

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Always enabled in production. Limits:
#   upload=10/min, telemetry=120/min, batch=20/min, status=60/min
RATE_LIMIT_ENABLED=true

# ── Backups ───────────────────────────────────────────────────────────────────
# Directory on the HOST where database backups are stored.
# The backup script (scripts/backup_db.sh) writes pg_dump files here.
# Set up a cron job: 0 2 * * * cd /path/to/routing_opt && ./scripts/backup_db.sh
BACKUP_DIR=./backups

# How many daily backups to keep before rotating. 7 = one week.
RETAIN_COUNT=7

# ── Script Overrides (optional) ───────────────────────────────────────────
# Used by scripts/backup_db.sh and scripts/deploy.sh.
# Defaults are auto-detected. Override only if your setup differs.
# COMPOSE_FILE=docker-compose.prod.yml
# DB_CONTAINER=lpg-db-prod
# ENV_FILE=.env.production
