# API authentication key for mutating endpoints (POST)
# When set, all POST requests require X-API-Key header with this value.
# Leave empty for dev mode (no auth required).
API_KEY=

# Environment name — controls security behavior.
# "development" (default): allows empty API_KEY without warning
# "staging" / "production": logs a warning if API_KEY is unset
ENVIRONMENT=development

# Google Maps API — used for geocoding only
# Get a key at: https://console.cloud.google.com/apis/credentials
# Enable "Geocoding API" — free $200/month credit
GOOGLE_MAPS_API_KEY=your-key-here

# PostgreSQL (used by Docker Compose)
POSTGRES_USER=routing
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=routing_opt

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# OSRM (local Docker)
OSRM_URL=http://localhost:5000

# VROOM (local Docker)
VROOM_URL=http://localhost:3000

# CORS — comma-separated list of allowed frontend origins
# SECURITY: never use "*" in production. List your actual frontend URLs.
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# Rate limiting — protects against abuse on expensive endpoints
# Set to "false" to disable in tests/CI. Default: "true".
# Limits: upload=10/min, telemetry=120/min, batch=20/min, status=60/min
RATE_LIMIT_ENABLED=true
